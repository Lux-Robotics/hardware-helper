/* Auto-generated config for MSVC builds of libwdi. */
#ifndef LIBWDI_CONFIG_H
#define LIBWDI_CONFIG_H

#if !defined(_MSC_VER)
#error "This config is intended for MSVC builds."
#endif

/* WDF version is only used if WinUSB or libusbK are enabled. */
#define WDF_VER 1011
#define COINSTALLER_DIR "wdf"
#define X64_DIR "x64"

/* Embed libusb-win32 driver files from the following location. */
#define LIBUSB0_DIR "@LIBWDI_LIBUSB0_DIR_CONFIG@"

/* Architecture support. */
#if @LIBWDI_OPT_M32@
#define OPT_M32
#endif
#if @LIBWDI_OPT_M64@
#define OPT_M64
#endif

/* Debug message logging (toggleable). */
#define INCLUDE_DEBUG_LOGGING
#define ENABLE_LOGGING 1

#endif
